<script>
        // Simple Interaction logic
        const toggleBtn = document.getElementById('main-toggle');
        const toggleIcon = document.getElementById('toggle-icon');
        const waveformBars = document.querySelectorAll('.waveform-bar');
        const timerElement = document.getElementById('timer');
        
        let isPaused = false;
        let seconds = 984; // 16:24

        toggleBtn.addEventListener('click', () => {
            isPaused = !isPaused;
            toggleIcon.textContent = isPaused ? 'play_arrow' : 'pause';
            toggleBtn.classList.toggle('recording-glow', !isPaused);
            
            if (isPaused) {
                toggleBtn.classList.add('bg-primary');
                toggleBtn.classList.remove('bg-secondary');
            } else {
                toggleBtn.classList.add('bg-secondary');
                toggleBtn.classList.remove('bg-primary');
            }
        });

        // Simple Waveform Animation
        function animateWaveform() {
            if (!isPaused) {
                waveformBars.forEach(bar => {
                    const height = Math.floor(Math.random() * 80) + 20;
                    bar.style.height = `${height}%`;
                });
            }
            requestAnimationFrame(() => setTimeout(animateWaveform, 150));
        }
        animateWaveform();

        // Simple Timer logic
        setInterval(() => {
            if (!isPaused) {
                seconds++;
                const h = Math.floor(seconds / 3600).toString().padStart(2, '0');
                const m = Math.floor((seconds % 3600) / 60).toString().padStart(2, '0');
                const s = (seconds % 60).toString().padStart(2, '0');
                timerElement.textContent = `${h}:${m}:${s}`;
            }
        }, 1000);
    </script>
