          "spacing": {
            "stack-sm": "12px",
            "gutter": "16px",
            "container-padding": "20px",
            "stack-lg": "40px",
            "base": "8px",
            "stack-md": "24px"
          },
          "fontFamily": {
            "label-sm": ["Hanken Grotesk"],
            "body-md": ["Hanken Grotesk"],
            "body-lg": ["Hanken Grotesk"],
