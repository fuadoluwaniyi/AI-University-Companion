            "surface-bright": "#f9f9ff",
            "on-surface": "#111c2d",
            "on-surface-variant": "#464652",
            "surface": "#f9f9ff",
            "tertiary-fixed": "#e3e1ed",
            "on-primary-fixed": "#04006d",
            "on-background": "#111c2d",
            "secondary-container": "#6063ee",
            "tertiary-container": "#3d3e47",
            "tertiary": "#272831",
            "on-secondary-fixed": "#07006c",
