<style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .custom-shadow {
      box-shadow: 0px 4px 20px rgba(46, 49, 146, 0.06);
    }
    body {
      -webkit-tap-highlight-color: transparent;
    }
  </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-surface text-on-surface font-body-md min-h-screen flex flex-col items-center">
<!-- Main Shell Context: Quiz screen (Transactional/Focused) - Suppressing Global Nav -->
<main class="w-full max-w-md min-h-screen bg-surface flex flex-col relative overflow-hidden pb-12">
<!-- TopAppBar (Specific for Quiz) -->
<header class="w-full px-container-padding py-base flex justify-between items-center bg-surface sticky top-0 z-10">
<button class="p-2 hover:bg-surface-container-low transition-colors rounded-full active:scale-95 duration-200">
<span class="material-symbols-outlined text-on-surface-variant">arrow_back_ios</span>
</button>
<h1 class="font-headline-md text-headline-md text-primary">Quiz</h1>
<button class="p-2 hover:bg-surface-container-low transition-colors rounded-full active:scale-95 duration-200">
<span class="material-symbols-outlined text-on-surface-variant">close</span>
</button>
</header>
<!-- Content Canvas -->
<div class="px-container-padding flex-1 flex flex-col gap-stack-md mt-4">
<!-- Progress Indicator -->
<section class="flex flex-col gap-2">
<div class="flex justify-center">
<p class="font-label-md text-label-md text-on-surface-variant">Question 4 of 10</p>
</div>
<div class="w-full h-1.5 bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full w-[40%] bg-primary transition-all duration-500 ease-out"></div>
</div>
</section>
<!-- Question Text -->
<section class="py-stack-sm">
<h2 class="font-headline-md text-headline-md text-primary leading-tight">
          What is the main function of the chloroplast in photosynthesis?
        </h2>
</section>
<!-- Quiz Options (Bento-like Card Pattern) -->
<section class="flex flex-col gap-stack-sm">
<!-- Option A -->
<button class="w-full p-5 bg-surface-container-lowest custom-shadow rounded-2xl flex items-center gap-gutter border border-transparent hover:border-outline-variant transition-all active:scale-[0.98]">
<div class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-low font-label-md text-label-md text-on-surface-variant">A</div>
<span class="font-body-lg text-body-lg text-on-surface">Produce ATP</span>
</button>
<!-- Option B (Correct State) -->
<button class="w-full p-5 bg-green-50 border-2 border-green-500 rounded-2xl flex items-center justify-between transition-all shadow-sm">
<div class="flex items-center gap-gutter">
<div class="w-10 h-10 flex items-center justify-center rounded-full bg-green-200 font-label-md text-label-md text-green-800">B</div>
<span class="font-body-lg text-body-lg text-green-900">Absorb light energy</span>
</div>
<span class="material-symbols-outlined text-green-600" style="font-variation-settings: 'wght' 700;">check</span>
</button>
<!-- Option C -->
<button class="w-full p-5 bg-surface-container-lowest custom-shadow rounded-2xl flex items-center gap-gutter border border-transparent hover:border-outline-variant transition-all active:scale-[0.98]">
<div class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-low font-label-md text-label-md text-on-surface-variant">C</div>
<span class="font-body-lg text-body-lg text-on-surface">Store water</span>
</button>
<!-- Option D -->
<button class="w-full p-5 bg-surface-container-lowest custom-shadow rounded-2xl flex items-center gap-gutter border border-transparent hover:border-outline-variant transition-all active:scale-[0.98]">
<div class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-low font-label-md text-label-md text-on-surface-variant">D</div>
<span class="font-body-lg text-body-lg text-on-surface">Break down glucose</span>
</button>
</section>
<!-- Feedback Section -->
<section class="mt-2 flex items-center gap-2 animate-pulse">
<span class="material-symbols-outlined text-yellow-500" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
<span class="font-label-md text-label-md text-green-600">Great job!</span>
</section>
</div>
<!-- Persistent CTA Button -->
<div class="mt-auto px-container-padding pt-stack-md pb-container-padding w-full">
<button class="w-full py-4 bg-success text-white font-headline-md text-headline-md rounded-2xl shadow-lg shadow-green-200 active:scale-95 transition-all duration-200">
        Next Question
      </button>
</div>
</main>
<!-- Lightweight Script for Interaction -->
<script>
    // Simple ripple/click effect for options
    document.querySelectorAll('button').forEach(button => {
      button.addEventListener('mousedown', function() {
        this.style.transform = 'scale(0.97)';
      });
      button.addEventListener('mouseup', function() {
        this.style.transform = '';
      });
      button.addEventListener('mouseleave', function() {
        this.style.transform = '';
      });
    });
  </script>
</body></html>
