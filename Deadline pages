<script>
    // Interaction logic for the list items
    document.querySelectorAll('.cursor-pointer').forEach(item => {
        item.addEventListener('click', function() {
            // Remove existing selection styling
            const currentSelectedRow = document.querySelector('.bg-surface-container-low\\/30');
            if (currentSelectedRow) {
                currentSelectedRow.classList.remove('bg-surface-container-low/30', '-mx-container-padding', 'px-container-padding');
                const label = currentSelectedRow.querySelector('span:first-child');
                label.classList.remove('font-bold', 'text-primary');
                label.classList.add('text-on-surface');
                const check = currentSelectedRow.querySelector('.material-symbols-outlined:not([data-icon="chevron_right"])');
                if (check && check.textContent === 'check') check.remove();
            }

            // Apply to new item if it's not the Custom row
            const isCustom = this.querySelector('span:last-child').textContent === 'chevron_right';
            if (!isCustom) {
                this.classList.add('bg-surface-container-low/30', '-mx-container-padding', 'px-container-padding');
                const label = this.querySelector('span:first-child');
                label.classList.add('font-bold', 'text-primary');
                label.classList.remove('text-on-surface');
                
                const check = document.createElement('span');
                check.className = 'material-symbols-outlined text-primary';
                check.style.fontVariationSettings = "'wght' 600";
                check.textContent = 'check';
                this.appendChild(check);
            }
        });
    });
</script>
